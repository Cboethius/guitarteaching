# Site
NEXT_PUBLIC_SITE_URL=https://www.learn2strum.ch
NEXT_PUBLIC_INTRO_VIDEO_URL=

# Stripe (https://dashboard.stripe.com — Switzerland, CHF)
# Use matching test OR live keys — never mix sk_test with pk_live.
# Local webhooks: run `npm run stripe:listen` and paste the whsec_... it prints here.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Direct payment (shown after booking)
PAYMENT_IBAN=CH15 0070 0114 5000 9980 7
PAYMENT_ACCOUNT_NAME=Christian Boethius
TWINT_PHONE=+41 76 805 86 68
TWINT_PAYLINK=

# Admin (testimonial approval workflow)
# Use a long random password (20+ characters). Never commit the real value.
ADMIN_PASSWORD=

# Vercel Blob (required on Vercel for testimonials + bookings storage)
# Without this on Vercel, bookings/testimonials may be lost between requests.
# Create in Vercel: Storage → Blob → Connect to project
BLOB_READ_WRITE_TOKEN=

# Optional: Resend for emails
# RESEND_API_KEY=
# BOOKING_NOTIFY_EMAIL=info@learn2strum.com
# Site notification emails also CC christian@boethius.ch (see site.emailSecondary).
# RESEND_FROM=learn2strum.ch <onboarding@resend.dev>

# Optional: LanguageTool (copy check via npm run check:copy)
# LANGUAGETOOL_API_URL=https://api.languagetool.org/v2/check
# LANGUAGETOOL_API_KEY=
